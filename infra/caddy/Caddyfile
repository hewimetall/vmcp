# Caddy fronts vmcp with HTTPS via its internal CA.
#
# `tls internal` makes Caddy mint a self-signed cert from a local root CA
# stored in the caddy-data volume. Trust the root cert by exporting
# /data/caddy/pki/authorities/local/root.crt and importing into your trust
# store. For a real public hostname, replace `localhost` with the domain
# and `tls internal` with `tls you@example.com` — Caddy will fetch a
# Let's Encrypt cert automatically.

{
    # Local CA only; no external ACME directory.
    local_certs
    auto_https disable_redirects
}

# Bind the cert to "localhost" (the SNI clients send when curling
# https://localhost/...). Add more `localhost, vmcp.local, ...` entries
# here when the gateway gets exposed under additional names.
localhost {
    tls internal

    # MCP streamable HTTP — keep streaming-friendly buffering.
    reverse_proxy /mcp* vmcp:8765 {
        flush_interval -1
    }

    # GraphQL semantic layer.
    reverse_proxy /graphql vmcp:8765

    # Liveness.
    reverse_proxy /health vmcp:8765
}

# Plain HTTP on :80 for local debugging only — remove for prod.
:80 {
    reverse_proxy /health vmcp:8765
}
