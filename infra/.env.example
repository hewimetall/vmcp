# vmcp prod deployment env vars.
# Copy this to `.env` next to the compose files and fill in real values.
# Do NOT commit `.env`.
#
#   cp infra/.env.example infra/compose/.env
#   $EDITOR infra/compose/.env

# --- Required: public surface ---
# DNS A record VMCP_DOMAIN → this host must be in place before first
# `docker compose up` so Caddy can complete the ACME HTTP-01 challenge.
VMCP_DOMAIN=mcp.runmcp.ru
VMCP_ACME_EMAIL=admin@runmcp.ru

# --- Required: master password (argon2id hash) ---
# vmcp's OAuth /consent flow and /admin Basic Auth gate against this.
# Generate ONCE on any host that already has the image built:
#
#   docker run --rm vmcp:source hash-password
#
# Paste the resulting `$argon2id$v=19$...` string below — keep the
# leading `$`, compose passes the value through verbatim.
VMCP_MASTER_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$REPLACE$REPLACE_WITH_REAL_HASH

# The Rust gateway no longer needs:
#   VMCP_JWT_SECRET     — replaced by locally-rotated JWKS (jwks_rotate_secs)
#   VMCP_AUTH_PASSWORD  — replaced by the argon2id hash above
#   ANTHROPIC_API_KEY / PERPLEXITY_API_KEY / GEMINI_API_KEY
#     — the public demo set is time + postgres + container-use,
#       none of which need third-party API keys.
