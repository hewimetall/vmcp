# Copy to .env and fill in before `docker compose up -d`
# (or run ./deploy/bootstrap.sh --domain <host>).
#
# Full guide: docs/deployment.md and docs/authentication.md

# Public domain (must resolve to this host — DNS A record → VPS IP).
VMCP_DOMAIN=gateway.example.com

# Runtime image from the GitHub Actions `release` workflow
# (`.github/workflows/release.yml` → GHCR on every `v*` tag).
# Examples:
#   ghcr.io/hewimetall/vmcp:latest
#   ghcr.io/hewimetall/vmcp:1.0.0
#   ghcr.io/hewimetall/vmcp:sha-abc1234
# For a local Dockerfile build use: vmcp:local  (+ docker-compose.build.yml)
VMCP_IMAGE=ghcr.io/hewimetall/vmcp:latest

# ---------------------------------------------------------------------------
# Master password (argon2id PHC hash — NOT the plaintext password)
# ---------------------------------------------------------------------------
#
# Generate (preferred — uses the same release image):
#   ./deploy/bootstrap.sh --domain gateway.example.com --password 'your-secret'
# Or manually:
#   docker run --rm --entrypoint /usr/local/bin/vmcp ghcr.io/hewimetall/vmcp:latest \
#     hash-password --password 'your-secret'
#
# Example output (single $ — what vmcp expects internally):
#   $argon2id$v=19$m=19456,t=2,p=1$AbCdEfGhIjKlMnOpQrStUv$XyZ123...
#
# In THIS FILE every $ MUST be doubled as $$ — Docker Compose interpolates $VAR.
# Wrong (corrupted hash, boot fails or password never matches):
#   VMCP_MASTER_PASSWORD_ARGON2=$argon2id$v=19$m=19456,t=2,p=1$SALT$HASH
# Right:
#   VMCP_MASTER_PASSWORD_ARGON2=$$argon2id$$v=19$$m=19456,t=2,p=1$$SALT$$HASH
#
# After editing: docker compose up -d --force-recreate vmcp
# Verify:        docker compose exec vmcp print-config | rg master_password
#
VMCP_MASTER_PASSWORD_ARGON2=$$argon2id$$v=19$$m=19456,t=2,p=1$$REPLACE_SALT$$REPLACE_DIGEST
