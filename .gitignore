# игнорируйте и его.
tokens.json
tokens.json.tmp*

# Dumps сессий recorder (runtime data — по умолчанию recorder.sessions_dir)
sessions/

# Локальное состояние SQLite (DCR clients, опциональная tasks DB)
state/

.env

# Выходные файлы release (tar.gz, zip)
dist/

