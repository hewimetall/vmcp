# Production Caddyfile — TLS termination + reverse proxy.
#
# Auth is handled by vmcp itself (OAuth 2.1 AS with master-password
# consent + JWKS-rotated JWT). Caddy just terminates TLS and proxies
# everything through.
#
# Cert lifecycle: Caddy uses ACME HTTP-01 challenge on :80 (kept open
# permanently — Let's Encrypt re-validates on every renewal). Cert is
# persisted in the caddy-data volume so restarts don't re-issue.
#
# Required env vars:
#   {$VMCP_DOMAIN}      — public hostname (DNS A record → this host)
#   {$VMCP_ACME_EMAIL}  — Let's Encrypt contact email

{
    email {$VMCP_ACME_EMAIL}
}

{$VMCP_DOMAIN} {
    # MCP streamable HTTP — disable buffering so SSE/keepalive frames flow
    # through immediately.
    handle /mcp* {
        reverse_proxy vmcp:8765 {
            flush_interval -1
        }
    }

    # Anthropic's Claude connector (and several other MCP clients) ignore
    # the PRM `resource` field and POST JSON-RPC straight at the bare
    # connector URL the operator typed — usually `https://<host>` with no
    # /mcp suffix. Rewriting the exact `/` path to `/mcp` lets that work
    # without forcing every user to edit the connector URL. Sub-paths fall
    # through to the routes below (well-known, register, admin, ...).
    handle / {
        rewrite * /mcp
        reverse_proxy vmcp:8765 {
            flush_interval -1
        }
    }

    # OAuth 2.1 AS endpoints (mounted by vmcp-auth).
    #   /.well-known/oauth-authorization-server
    #   /.well-known/oauth-protected-resource
    #   /.well-known/jwks.json
    handle /.well-known/* {
        reverse_proxy vmcp:8765
    }
    handle /authorize* {
        reverse_proxy vmcp:8765
    }
    handle /token {
        reverse_proxy vmcp:8765
    }
    handle /register {
        reverse_proxy vmcp:8765
    }
    handle /consent* {
        reverse_proxy vmcp:8765
    }

    # Liveness — open.
    handle /health {
        reverse_proxy vmcp:8765
    }

    # Admin UI (HTTP Basic via vmcp; CSP/HSTS/X-Frame stamped by vmcp's
    # security middleware so we don't double them in Caddy).
    #
    # axum's .nest("/admin", ...) routes /admin and /admin/<sub> correctly
    # but 404s on bare /admin/ (with trailing slash) — handle that exact
    # path first and 308-redirect so browsers that auto-append don't get
    # a wall. Per-handle order in Caddy is matcher-specific: `/admin/`
    # (exact) wins over `/admin*` (prefix), so this stays correct.
    handle /admin/ {
        redir * /admin 308
    }
    handle /admin* {
        reverse_proxy vmcp:8765
    }

    # Everything not matched above → 404. Without this, Caddy returns an
    # empty 200 for /docs, /openapi.json, etc. — confusing for clients and
    # masks the fact that those endpoints were intentionally disabled.
    handle {
        respond "Not Found" 404
    }

    encode zstd gzip
    log {
        output stdout
        format json
    }
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }
}
