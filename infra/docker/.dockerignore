# Build context is the repo root. Exclude things that bloat the image
# or leak host state.

**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/
**/*.egg-info/
**/dist/
**/build/
**/sandbox-tmp/

# Working state we don't want in images
demo_project/registry.json
demo_project/data/
demo_project/.env
demo_project/tests/
demo_project/smoke.sh

# Rust intermediates (target/) — host-built, irrelevant in Docker stages
mcp/**/target/

# Repo-level paraphernalia
.git/
.gitignore
presentation/
infra/compose/
